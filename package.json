{
  "name": "env-enforce",
  "version": "1.0.1",
  "description": "Zero-dependency, fail-fast environment variable validator for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/env.test.mjs",
    "test:smoke": "npm run build && node test/smoke.mjs",
    "prepublishOnly": "npm run build",
    "publish:dry-run": "npm run build && npm publish --access public --dry-run"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decept1kon/env-enforce.git"
  },
  "keywords": [
    "dotenv",
    "env",
    "environment",
    "env validation",
    "config",
    "configuration",
    "runtime validation",
    "ci",
    "startup",
    "node",
    "typescript",
    "production",
    "schema",
    "guard"
  ],
  "author": "Decept1kon",
  "license": "MIT",
  "devDependencies": {
    "typescript": "~5.3.0",
    "@types/node": "^20.0.0"
  }
}
